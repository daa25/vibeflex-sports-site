<section class="page-width section-spacing"><header class="collection-header"><p class="eyebrow">490 MOVEMENT</p><h1>{{ collection.title }}</h1>{% if collection.description != blank %}<div class="rte">{{ collection.description }}</div>{% endif %}</header>{% paginate collection.products by section.settings.products_per_page %}<div class="product-grid">{% for product in collection.products %}{% render 'product-card', product: product %}{% else %}<p>No products found in this collection.</p>{% endfor %}</div>{{ paginate | default_pagination }}{% endpaginate %}</section>{% schema %}{"name":"Main collection","settings":[{"type":"range","id":"products_per_page","label":"Products per page","min":4,"max":48,"step":4,"default":24}]}{% endschema %}