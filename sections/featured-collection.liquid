{% assign collection = section.settings.collection %}
<section class="page-width section-space">
  <div class="section-heading"><p class="eyebrow">{{ section.settings.eyebrow }}</p><h2>{{ section.settings.heading }}</h2></div>
  {% if collection != blank %}
    <div class="product-grid">
      {% for product in collection.products limit: section.settings.products_to_show %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
    <a class="button" href="{{ collection.url }}">View collection</a>
  {% else %}<p>Select a collection in the theme editor.</p>{% endif %}
</section>
{% schema %}{"name":"Featured collection","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"AVAILABLE NOW"},{"type":"text","id":"heading","label":"Heading","default":"SHOP THE MENTALITY."},{"type":"collection","id":"collection","label":"Collection"},{"type":"range","id":"products_to_show","label":"Products","min":4,"max":12,"step":4,"default":8}],"presets":[{"name":"Featured collection"}]}{% endschema %}