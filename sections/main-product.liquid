<section class="page-width product-page">
  <div class="product-gallery">
    {% for media in product.media %}
      {{ media.preview_image | image_url: width: 1400 | image_tag: loading: 'lazy', alt: media.alt | default: product.title }}
    {% endfor %}
  </div>
  <div class="product-details">
    {% if product.vendor != blank %}<p class="eyebrow">{{ product.vendor }}</p>{% endif %}
    <h1>{{ product.title }}</h1>
    <div class="product-price">{{ product.selected_or_first_available_variant.price | money }}</div>
    <div class="rte">{{ product.description }}</div>
    {% form 'product', product %}
      {% unless product.has_only_default_variant %}
        <label for="Variant-{{ section.id }}">Options</label>
        <select id="Variant-{{ section.id }}" name="id">
          {% for variant in product.variants %}<option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>{{ variant.title }} — {{ variant.price | money }}</option>{% endfor %}
        </select>
      {% else %}<input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">{% endunless %}
      <label for="Quantity-{{ section.id }}">Quantity</label><input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1">
      <button class="button" type="submit" {% unless product.available %}disabled{% endunless %}>{% if product.available %}Add to cart{% else %}Sold out{% endif %}</button>
      {{ form | payment_button }}
    {% endform %}
    <ul class="trust-list"><li>Secure Shopify checkout</li><li>Order confirmation by email</li><li>{% if product.tags contains 'digital' %}Digital delivery after purchase{% else %}Shipping calculated at checkout{% endif %}</li></ul>
  </div>
</section>
{% schema %}{"name":"Main product","settings":[]}{% endschema %}