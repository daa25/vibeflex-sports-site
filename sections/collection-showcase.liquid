<section class="collection-showcase section-space">
  <div class="page-width">
    <div class="section-heading collection-showcase__heading">
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.text != blank %}<div class="rte collection-showcase__intro">{{ section.settings.text }}</div>{% endif %}
    </div>

    <div class="collection-showcase__grid">
      {% for block in section.blocks %}
        {% assign collection = block.settings.collection %}
        <article class="collection-tile collection-tile--{{ forloop.index }}" {{ block.shopify_attributes }}>
          <a href="{% if collection != blank %}{{ collection.url }}{% else %}{{ block.settings.link }}{% endif %}" class="collection-tile__link">
            <div class="collection-tile__media">
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'collection-tile__image', alt: block.settings.heading }}
              {% elsif collection.featured_image != blank %}
                {{ collection.featured_image | image_url: width: 1600 | image_tag: loading: 'lazy', class: 'collection-tile__image', alt: collection.title }}
              {% else %}
                {{ 'collection-1' | placeholder_svg_tag: 'collection-tile__placeholder' }}
              {% endif %}
              <div class="collection-tile__overlay"></div>
            </div>
            <div class="collection-tile__content">
              <p class="collection-tile__kicker">{{ block.settings.kicker }}</p>
              <h3>{% if block.settings.heading != blank %}{{ block.settings.heading }}{% elsif collection != blank %}{{ collection.title }}{% endif %}</h3>
              <p>{{ block.settings.description }}</p>
              <span class="collection-tile__cta">{{ block.settings.button_label }} <span aria-hidden="true">→</span></span>
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection showcase",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"SHOP BY IDENTITY"},
    {"type":"text","id":"heading","label":"Heading","default":"BUILT FOR MORE."},
    {"type":"richtext","id":"text","label":"Intro","default":"<p>Performance gear, faith-driven apparel, and tools built to keep you moving.</p>"}
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection card",
      "settings": [
        {"type":"collection","id":"collection","label":"Collection"},
        {"type":"image_picker","id":"image","label":"Custom image"},
        {"type":"text","id":"kicker","label":"Kicker","default":"490 MOVEMENT"},
        {"type":"text","id":"heading","label":"Heading","default":"#UNCOOKED"},
        {"type":"textarea","id":"description","label":"Description","default":"Redeemed. Rewired. Uncooked."},
        {"type":"text","id":"button_label","label":"Button label","default":"Shop collection"},
        {"type":"url","id":"link","label":"Fallback link"}
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Collection showcase",
      "blocks": [
        {"type":"collection","settings":{"kicker":"490 MOVEMENT","heading":"#UNCOOKED","description":"Cooked by sin. Uncooked by grace."}},
        {"type":"collection","settings":{"kicker":"PREMIUM HEADWEAR","heading":"CHSN","description":"Purpose-driven essentials made to represent."}},
        {"type":"collection","settings":{"kicker":"PERFORMANCE","heading":"MINDSET SLEEVES™","description":"Wear your mindset. Own every rep."}},
        {"type":"collection","settings":{"kicker":"VIBEFLEX SPORTS","heading":"BUILT DIFFERENT","description":"Grind. Gameday. Everyday."}}
      ]
    }
  ]
}
{% endschema %}