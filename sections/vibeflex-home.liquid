<section class="vf-hero" style="--overlay:{{ section.settings.overlay | divided_by: 100.0 }}">
  {% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 2400 | image_tag: class: 'vf-hero__image', loading: 'eager', fetchpriority: 'high' }}{% endif %}
  <div class="vf-hero__overlay"></div>
  <div class="page-width vf-hero__content"><p>{{ section.settings.eyebrow }}</p><h1>{{ section.settings.heading }}</h1><div class="rte">{{ section.settings.text }}</div><div class="vf-actions">{% if section.settings.button_label != blank %}<a class="button" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>{% endif %}{% if section.settings.secondary_label != blank %}<a class="button button--outline" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>{% endif %}</div></div>
</section>
<section class="vf-values">{% for block in section.blocks %}<div {{ block.shopify_attributes }}><strong>{{ block.settings.heading }}</strong><span>{{ block.settings.text }}</span></div>{% endfor %}</section>
{% schema %}{"name":"VibeFlex hero","settings":[{"type":"image_picker","id":"image","label":"Hero image"},{"type":"range","id":"overlay","label":"Overlay","min":0,"max":90,"step":5,"default":45},{"type":"text","id":"eyebrow","label":"Eyebrow","default":"BUILT FOR THE ONES WHO NEVER CLOCK OUT"},{"type":"text","id":"heading","label":"Heading","default":"WEAR THE MINDSET."},{"type":"richtext","id":"text","label":"Text","default":"<p>Performance apparel, digital tools, and limited drops for athletes, creators, and competitors.</p>"},{"type":"text","id":"button_label","label":"Primary button","default":"Shop now"},{"type":"url","id":"button_link","label":"Primary link"},{"type":"text","id":"secondary_label","label":"Secondary button","default":"Explore collections"},{"type":"url","id":"secondary_link","label":"Secondary link"}],"blocks":[{"type":"value","name":"Value","settings":[{"type":"text","id":"heading","label":"Heading","default":"STAY READY"},{"type":"text","id":"text","label":"Text","default":"Built for the work before the moment."}]}],"presets":[{"name":"VibeFlex hero","blocks":[{"type":"value"},{"type":"value"},{"type":"value"}]}]}{% endschema %}