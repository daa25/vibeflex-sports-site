<section class="vf-hero" style="--overlay:{{ section.settings.overlay | divided_by: 100.0 }}">
  {% if section.settings.image != blank %}{{ section.settings.image | image_url: width: 2400 | image_tag: class: 'vf-hero__image', loading: 'eager', fetchpriority: 'high' }}{% endif %}
  <div class="vf-hero__overlay"></div>
  <div class="page-width vf-hero__content">
    <p>{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <div class="rte">{{ section.settings.text }}</div>
    <div class="vf-actions">
      {% if section.settings.button_label != blank %}<a class="button" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>{% endif %}
      {% if section.settings.secondary_label != blank %}<a class="button button--outline" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>{% endif %}
    </div>
  </div>
</section>
<section class="vf-values">{% for block in section.blocks %}<div {{ block.shopify_attributes }}><strong>{{ block.settings.heading }}</strong><span>{{ block.settings.text }}</span></div>{% endfor %}</section>
{% schema %}
{"name":"490 Movement hero","settings":[{"type":"image_picker","id":"image","label":"Hero image"},{"type":"range","id":"overlay","label":"Overlay","min":0,"max":90,"step":5,"default":50},{"type":"text","id":"eyebrow","label":"Eyebrow","default":"490 MOVEMENT"},{"type":"text","id":"heading","label":"Heading","default":"DISCIPLINE. FAITH. MOVEMENT."},{"type":"richtext","id":"text","label":"Text","default":"<p>Purpose-driven apparel and essentials for people committed to growth, belief, and forward motion.</p>"},{"type":"text","id":"button_label","label":"Primary button","default":"Shop the movement"},{"type":"url","id":"button_link","label":"Primary link"},{"type":"text","id":"secondary_label","label":"Secondary button","default":"Our story"},{"type":"url","id":"secondary_link","label":"Secondary link"}],"blocks":[{"type":"value","name":"Brand pillar","settings":[{"type":"text","id":"heading","label":"Heading","default":"DISCIPLINE"},{"type":"text","id":"text","label":"Text","default":"Show up. Stay consistent. Finish the work."}]}],"presets":[{"name":"490 Movement hero","blocks":[{"type":"value","settings":{"heading":"DISCIPLINE","text":"Show up. Stay consistent. Finish the work."}},{"type":"value","settings":{"heading":"FAITH","text":"Move with purpose, conviction, and belief."}},{"type":"value","settings":{"heading":"MOVEMENT","text":"Progress is a decision made every day."}}]}]}
{% endschema %}