<section class="newsletter section-spacing"><div class="page-width newsletter__inner"><p class="eyebrow">{{ section.settings.eyebrow }}</p><h2>{{ section.settings.heading }}</h2><div class="rte">{{ section.settings.text }}</div>{% form 'customer', class: 'newsletter-form' %}<input type="hidden" name="contact[tags]" value="newsletter"><label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">Email</label><input id="NewsletterEmail-{{ section.id }}" type="email" name="contact[email]" placeholder="Email address" required><button class="button" type="submit">Join the movement</button>{% if form.posted_successfully? %}<p>You're in. Watch your inbox.</p>{% endif %}{{ form.errors | default_errors }}{% endform %}</div></section>{% schema %}{"name":"Newsletter","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"JOIN THE MOVEMENT"},{"type":"text","id":"heading","label":"Heading","default":"STAY READY FOR THE NEXT DROP."},{"type":"richtext","id":"text","label":"Text","default":"<p>Get launch updates, limited releases, and community news.</p>"}],"presets":[{"name":"Newsletter"}]}{% endschema %}