<section class="page-width section-spacing"><header><p class="eyebrow">490 MOVEMENT</p><h1>Your cart</h1></header>{% if cart.item_count == 0 %}<p>Your cart is empty.</p><a class="button" href="{{ routes.all_products_collection_url }}">Shop the movement</a>{% else %}<form action="{{ routes.cart_url }}" method="post" novalidate><div class="cart-lines">{% for item in cart.items %}<div class="cart-line"><a href="{{ item.url }}">{% if item.image %}{{ item.image | image_url: width: 240 | image_tag: loading: 'lazy' }}{% endif %}</a><div><a href="{{ item.url }}"><strong>{{ item.product.title }}</strong></a><p>{{ item.variant.title }}</p><label>Quantity <input type="number" name="updates[]" value="{{ item.quantity }}" min="0"></label><a href="{{ item.url_to_remove }}">Remove</a></div><strong>{{ item.final_line_price | money }}</strong></div>{% endfor %}</div><div class="cart-summary"><p>Subtotal <strong>{{ cart.total_price | money }}</strong></p><p>Taxes and shipping calculated at checkout.</p><button class="button button--outline" type="submit" name="update">Update cart</button><button class="button" type="submit" name="checkout">Checkout</button></div></form>{% endif %}</section>{% schema %}{"name":"Main cart","settings":[]}{% endschema %}