<article class="product-card">
  <a href="{{ product.url }}" class="product-media">
    {% if product.featured_image %}{{ product.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: product.title }}{% else %}<div class="product-placeholder">VF</div>{% endif %}
  </a>
  <div class="product-info">
    {% if product.tags contains 'digital' %}<span class="product-badge">Digital download</span>{% endif %}
    <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
    <div class="product-price">{% if product.compare_at_price > product.price %}<s>{{ product.compare_at_price | money }}</s>{% endif %} {{ product.price | money }}</div>
    {% form 'product', product %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <button class="button" type="submit" {% unless product.available %}disabled{% endunless %}>{% if product.available %}Add to cart{% else %}Sold out{% endif %}</button>
    {% endform %}
  </div>
</article>